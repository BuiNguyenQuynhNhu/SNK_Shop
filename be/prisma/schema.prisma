generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================= ENUM =================
enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  MOMO
  VNPAY
}

enum PromotionType {
  PERCENT
  FIXED_AMOUNT
}

enum MediaType {
  BRAND
  SNEAKER
  VARIANT
}

enum ImageType {
  MAIN
  FRONT
  BACK
  SIDE
  DETAIL
  GALLERY
}

// ================= USER =================
model User {
  id Int @id @default(autoincrement())

  email        String @unique
  password String
  name         String
  phone        String @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  customer Customer?
  employee Employee?
}

// ================= CUSTOMER =================
model Customer {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  addresses Address[]
  cart      Cart?
  favourite Favourite?
  orders    Order[]
}

// ================= ADDRESS =================
model Address {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  street      String
  city        String
  province    String
  fullAddress String

  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ================= MEDIA =================
model Media {
  id Int @id @default(autoincrement())

  url String @unique

  fileName String?
  mimeType String?
  size     Int?

  type      MediaType
  imageType ImageType?

  brandLogo   Brand? @relation("BrandLogo")
  brandImages Brand[] @relation("BrandImages")

  variantImage Variant? @relation("VariantImage")
  employeeImage Employee? @relation("EmployeeImage")

  createdAt DateTime @default(now())
}

// ================= BRAND =================
model Brand {
  id Int @id @default(autoincrement())

  name        String @unique
  description String?

  logoId Int? @unique
  logo   Media? @relation("BrandLogo", fields: [logoId], references: [id])

  images Media[] @relation("BrandImages")

  sneakers Sneaker[]
}

// ================= CATEGORY =================
model Category {
  id Int @id @default(autoincrement())

  name        String @unique
  description String?

  sneakers Sneaker[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ================= SNEAKER =================
model Sneaker {
  id Int @id @default(autoincrement())

  name        String
  description String

  brandId Int
  brand   Brand @relation(fields: [brandId], references: [id])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  variants Variant[]

  favouriteItems FavouriteItem[]

  createdById Int?
  createdBy   Employee? @relation("SneakerCreatedBy", fields: [createdById], references: [id])

  updatedById Int?
  updatedBy   Employee? @relation("SneakerUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([brandId])
  @@index([categoryId])
  @@index([deletedAt])
}

// ================= VARIANT =================
model Variant {
  id Int @id @default(autoincrement())

  sneakerId Int
  sneaker   Sneaker @relation(fields: [sneakerId], references: [id])

  color String
  size  Int

  price Decimal @db.Decimal(10, 2)
  stock Int

  imageId Int? @unique
  image   Media? @relation("VariantImage", fields: [imageId], references: [id])

  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sneakerId, color, size])
}

// ================= PROMOTION =================
model Promotion {
  id Int @id @default(autoincrement())

  code String? @unique

  name        String
  description String?

  type  PromotionType
  value Decimal @db.Decimal(10, 2)

  startDate DateTime
  endDate   DateTime

  minOrderValue Decimal?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

// ================= CART =================
model Cart {
  id Int @id @default(autoincrement())

  customerId Int @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  items CartItem[]

  updatedAt DateTime @updatedAt
}

model CartItem {
  id Int @id @default(autoincrement())

  cartId Int
  cart   Cart @relation(fields: [cartId], references: [id])

  variantId Int
  variant   Variant @relation(fields: [variantId], references: [id])

  quantity Int @default(1)

  @@unique([cartId, variantId])
}

// ================= FAVOURITE =================
model Favourite {
  id Int @id @default(autoincrement())

  customerId Int @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  items FavouriteItem[]
}

model FavouriteItem {
  id Int @id @default(autoincrement())

  favouriteId Int
  favourite   Favourite @relation(fields: [favouriteId], references: [id])

  sneakerId Int
  sneaker   Sneaker @relation(fields: [sneakerId], references: [id])

  @@unique([favouriteId, sneakerId])
}

// ================= EMPLOYEE =================
model Employee {
  id Int @id @default(autoincrement())

  userId Int @unique
  user   User @relation(fields: [userId], references: [id])

  imageId Int? @unique
  image   Media? @relation("EmployeeImage", fields: [imageId], references: [id])

  role     Role    @default(STAFF)
  isActive Boolean @default(true)

  salaries        SalaryHistory[]
  createdSneakers Sneaker[] @relation("SneakerCreatedBy")
  updatedSneakers Sneaker[] @relation("SneakerUpdatedBy")
}

model SalaryHistory {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  amount Decimal @db.Decimal(10, 2)
  note   String?

  createdAt DateTime @default(now())
}

// ================= ORDER =================
model Order {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  address String
  phone   String
  note    String?

  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod

  totalAmount    Decimal @db.Decimal(10, 2)
  shippingFee    Decimal @db.Decimal(10, 2) @default(0)
  discountAmount  Decimal @db.Decimal(10, 2) @default(0)
  finalAmount     Decimal @db.Decimal(10, 2)

  items   OrderItem[]
  payment Payment?

  promotionId Int?
  promotion   Promotion? @relation(fields: [promotionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([customerId])
  @@index([status])
}

// ================= ORDER ITEM =================
model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  variantId Int
  variant   Variant @relation(fields: [variantId], references: [id])

  name     String
  color    String
  size     Int

  price    Decimal @db.Decimal(10, 2)
  quantity Int
  total    Decimal @db.Decimal(10, 2)

  @@index([orderId])
}

// ================= PAYMENT =================
model Payment {
  id Int @id @default(autoincrement())

  orderId Int @unique
  order   Order @relation(fields: [orderId], references: [id])

  method PaymentMethod
  status PaymentStatus

  transactionId String?

  paidAt    DateTime?
  createdAt DateTime @default(now())
}