generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

model User {
  id Int @id @default(autoincrement())

  email    String @unique
  password String
  name     String

  phone   String   @unique
  address Address? @relation(fields: [addressId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee  Employee?
  customer  Customer?
  addressId Int?
}

// ================= CUSTOMER =================
model Customer {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  carts      Cart?
  favourites Favourite?
  orders     Order[]
  Address    Address?
}

// ================= ADDRESS =================
model Address {
  id          Int    @id @default(autoincrement())
  street      String
  province    String
  city        String
  fullAddress String

  customerId Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id])
  User       User[]
}

// ================= MEDIA =================
model Media {
  id   Int    @id @default(autoincrement())
  link String @unique

  brandLogos  Brand[] @relation("BrandLogo")
  brandImages Brand[] @relation("BrandImage")

  sneakerImages SneakerImage[]

  employeeImages Employee[] @relation("EmployeeImage")
}

// ================= BRAND =================
model Brand {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  logoId Int?
  logo   Media? @relation("BrandLogo", fields: [logoId], references: [id])

  imageId Int?
  image   Media? @relation("BrandImage", fields: [imageId], references: [id])

  sneakers Sneaker[]
}

// ================= SNEAKER =================
model Sneaker {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  basePrice   Float

  brandId Int
  brand   Brand @relation(fields: [brandId], references: [id])

  images     SneakerImage[]
  variants   Variant[]
  carts      CartItem[]
  favourites FavouriteItem[]
  prices     Price[]

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  OrderItem OrderItem[]
}

// ================= SNEAKER IMAGE (FIX) =================
model SneakerImage {
  id Int @id @default(autoincrement())

  sneakerId Int
  sneaker   Sneaker @relation(fields: [sneakerId], references: [id])

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id])
}

// ================= PRICE =================
model Price {
  id       Int    @id @default(autoincrement())
  price    Float
  discount Float?

  sneakerId Int
  sneaker   Sneaker @relation(fields: [sneakerId], references: [id])

  updateAt DateTime @updatedAt
}

// ================= VARIANT =================
model Variant {
  id Int @id @default(autoincrement())

  sneakerId Int
  sneaker   Sneaker @relation(fields: [sneakerId], references: [id])

  color String
  size  Int
  price Float
  stock Int

  image     String?
  CartItem  CartItem[]
  OrderItem OrderItem[]

  @@unique([sneakerId, color, size])
}

// ================= CART =================
model Cart {
  id Int @id @default(autoincrement())

  customerId Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  items CartItem[]
}

model CartItem {
  id Int @id @default(autoincrement())

  cartId Int
  cart   Cart @relation(fields: [cartId], references: [id])

  sneakerId Int
  sneaker   Sneaker @relation(fields: [sneakerId], references: [id])

  variantId Int
  variant   Variant @relation(fields: [variantId], references: [id])

  quantity Int @default(1)

  @@unique([cartId, variantId])
}

// ================= FAVOURITE =================
model Favourite {
  id Int @id @default(autoincrement())

  customerId Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  items FavouriteItem[]
}

model FavouriteItem {
  id Int @id @default(autoincrement())

  favouriteId Int
  favourite   Favourite @relation(fields: [favouriteId], references: [id])

  sneakerId Int
  sneaker   Sneaker @relation(fields: [sneakerId], references: [id])

  @@unique([favouriteId, sneakerId])
}

// ================= EMPLOYEE =================
model Employee {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  imageId Int?
  image   Media? @relation("EmployeeImage", fields: [imageId], references: [id])

  position String // STAFF | MANAGER
  isActive Boolean @default(true)

  salaries SalaryHistory[]
}

model SalaryHistory {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  amount    Float
  changedAt DateTime @default(now())

  note String?
}

// ================= ORDERS =================
enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  MOMO
  VNPAY
}

model Order {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  address String
  phone   String
  note    String?

  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod

  totalAmount Float
  shippingFee Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items   OrderItem[]
  Payment Payment?
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  sneakerId Int
  sneaker   Sneaker @relation(fields: [sneakerId], references: [id])

  variantId Int?
  variant   Variant? @relation(fields: [variantId], references: [id])

  name  String
  price Float

  quantity Int

  total Float
}

model Payment {
  id Int @id @default(autoincrement())

  orderId Int   @unique
  order   Order @relation(fields: [orderId], references: [id])

  method PaymentMethod
  status PaymentStatus

  transactionId String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
}
